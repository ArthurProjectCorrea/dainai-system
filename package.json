{
  "name": "dainai-system",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write . && dotnet format apps/api/Api.sln",
    "prepare": "husky",
    "postinstall": "dotnet restore apps/api/Api.sln"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/api/**/*.cs": [
      "dotnet format apps/api/Api.sln --include"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5"
  }
}
