# Runtime
ASPNETCORE_ENVIRONMENT=Development
TEST_MODE=false
SeedDatabase=true

# Database (used by db service)
POSTGRES_DB=dainaidb
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me

# API connection string (used by api service)
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=dainaidb;Username=user;Password=change_me

# Cache
Redis__ConnectionString=redis:6379

# SMTP
Smtp__Host=mailhog
Smtp__Port=1025
Smtp__SenderName=Sistema Dainai
Smtp__SenderEmail=noreply@dainai.com.br

# Frontend invitation URL
App__InvitationBaseUrl=http://localhost:3000/auth/reset-password

# Frontend web URL (CORS)
App__WebClientUrl=http://localhost:3000
